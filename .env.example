# ------------------------------
# SupplyWise environment template
# ------------------------------
# Copy this file to `.env` for local development.
# In Vercel, add these keys in Project Settings -> Environment Variables.

# AI providers
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# Frontend (exposed to browser via Vite)
VITE_ELEVENLABS_VOICE_ID=s3TPKV1kjDlVtZbl4Ksh
VITE_ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
VITE_ELEVENLABS_STT_MODEL_ID=scribe_v1

# Database connection (set at least one URL)
POSTGRES_URL=
DATABASE_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
SUPABASE_DB_URL=

# Optional: build a DB URL from separate parts if URL vars are not set
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Migration utility (optional)
SQLITE_PATH=data/db.sqlite
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
